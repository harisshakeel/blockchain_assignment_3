# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Your wallet private key (without 0x prefix is also fine)
PRIVATE_KEY=your_private_key_here

# Polygon Amoy RPC — get a free key from Alchemy or Infura
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# PolygonScan API key for contract verification (optional)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
